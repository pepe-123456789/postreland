<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Postreland | Brownies y Galletas</title>
    <style>
        /* FIX GLOBAL: Evita que los elementos se salgan del ancho de la pantalla */
        * { box-sizing: border-box; } 

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background: #fdf2e9 url('marco-pasteleria.png') no-repeat center center fixed;
            background-size: cover;
            color: #4a2c2a;
            scroll-behavior: smooth;
        }

        /* FIX DE FORMULARIOS: Ajuste perfecto para celular */
        input[type="text"], 
        input[type="email"], 
        input[type="number"] { 
            width: 100%; 
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 8px;
            margin-bottom: 10px;
            display: block;
            font-size: 16px; /* Evita el zoom automático en iPhone/Samsung */
        }

        .logo-negocio {
            width: 160px;
            height: auto;
            display: block;
            margin: 0 auto;
        }

        header {
            background-color: rgba(210, 105, 30, 0.95);
            padding: 1.5rem 0;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        nav ul {
            list-style: none;
            padding: 0;
            display: flex;
            justify-content: center;
            background-color: #5d3a3a;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        nav ul li a {
            color: white;
            text-decoration: none;
            padding: 12px 15px;
            display: block;
            font-weight: bold;
            font-size: 0.85rem;
        }

        main { max-width: 1100px; margin: 20px auto; padding: 0 15px; }

        section {
            background: rgba(255, 255, 255, 0.97);
            margin-bottom: 30px;
            padding: 25px;
            border-radius: 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            scroll-margin-top: 140px;
        }

        .grid-articulos {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        article {
            background: #fff;
            border-radius: 15px;
            overflow: hidden;
            border: 1px solid #eee;
        }

        article img { width: 100%; height: 220px; object-fit: cover; }

        .galeria-fotos {
            display: flex;
            gap: 10px;
            overflow-x: auto;
            padding-bottom: 10px;
        }
        .galeria-fotos img { height: 180px; border-radius: 10px; flex-shrink: 0; }

        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        th { background: #d2691e; color: white; padding: 12px; font-size: 0.8rem; }
        td { padding: 10px; border-bottom: 1px solid #eee; text-align: center; font-size: 0.9rem; }
        
        .opcion-pedido {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fdf2e9;
            padding: 10px;
            margin-bottom: 8px;
            border-radius: 8px;
        }

        .opcion-pedido div { display: flex; align-items: center; gap: 8px; }

        .btn-orden {
            background: #d2691e;
            color: white;
            border: none;
            padding: 15px;
            width: 100%;
            border-radius: 10px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
        }

        /* SECCIÓN DE HORARIO Y UBICACIÓN */
        footer { 
            background: #5d3a3a; 
            color: white; 
            text-align: center; 
            padding: 40px 20px; 
            margin-top: 40px;
        }

        .footer-info {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 20px;
        }

        .footer-info div { min-width: 200px; }

        .footer-info h3 { border-bottom: 1px solid #d2691e; padding-bottom: 5px; margin-bottom: 10px; }
    </style>
</head>
<body>

    <header>
        <img src="Gemini_Generated_Image_.Png" alt="Logo Postreland" class="logo-negocio">
        <p><em>Donde el chocolate se vuelve arte en La Chorrera.</em></p>
        <nav>
            <ul>
                <li><a href="#inicio">Inicio</a></li>
                <li><a href="#menu">Menú</a></li>
                <li><a href="#galeria">Momentos</a></li>
                <li><a href="#gestion">Socios</a></li>
                <li><a href="#pedido">Pedidos</a></li>
            </ul>
        </nav>
    </header>

    <main>
        <section id="inicio">
            <h2>Especialidades</h2>
            <div class="grid-articulos">
                <article>
                    <img src="porcion-brownie-chocolate.png" alt="Brownie Melcochoso">
                    <div style="padding:15px;"><h3>Melcochosos</h3><p>Suavidad extrema.</p></div>
                </article>
                <article>
                    <img src="browine 1.png" alt="Brownie">
                    <div style="padding:15px;"><h3>Tradicional</h3><p>La receta clásica.</p></div>
                </article>
            </div>
        </section>

        <section id="galeria">
            <h2>En la Cocina</h2>
            <div class="galeria-fotos">
                <img src="chocolate-chip-cookie.png" alt="Cocinando">
                <img src="browine.png" alt="Listo">
            </div>
        </section>

        <section id="menu">
            <h2>Nuestra Carta</h2>
            <table>
                <thead>
                    <tr><th>Postre</th><th>Imagen</th><th>Precio</th></tr>
                </thead>
                <tbody>
                    <tr onclick="seleccionar('check-nueces', 'cant-nueces')">
                        <td>Brownie Nueces</td>
                        <td><img src="porcion-brownie-chocolate.png" width="50" height="50" style="object-fit:cover; border-radius:5px;"></td>
                        <td>$2.50</td>
                    </tr>
                    <tr onclick="seleccionar('check-rojo', 'cant-rojo')">
                        <td>Red Velvet</td>
                        <td><img src="red cake-chocolate-chip-cookie-white.png" width="50" height="50" style="object-fit:cover; border-radius:5px;"></td>
                        <td>$1.75</td>
                    </tr>
                    <tr onclick="seleccionar('check-melco', 'cant-melco')">
                        <td>Melcochoso</td>
                        <td><img src="porcion-brownie-chocolate.png" width="50" height="50" style="object-fit:cover; border-radius:5px;"></td>
                        <td>$2.25</td>
                    </tr>
                    <tr onclick="seleccionar('check-base', 'cant-base')">
                        <td>Tradicional</td>
                        <td><img src="browine 1.png" width="50" height="50" style="object-fit:cover; border-radius:5px;"></td>
                        <td>$1.50</td>
                    </tr>
                </tbody>
            </table>
        </section>

        <section id="gestion">
            <h2>Registro de Socios</h2>
            <form id="form-registro">
                <input type="text" id="reg-nombre" placeholder="Nombre completo" required>
                <input type="email" id="reg-email" placeholder="Correo Gmail" required>
                <button type="submit" class="btn-orden">Registrarme</button>
            </form>
            <div id="mensaje-socio" style="display:none; text-align:center; padding:15px; border: 2px dashed #d2691e; margin-top:15px; border-radius:10px;">
                <p>¡Bienvenido/a, <span id="socio-nombre"></span>!</p>
                <p>Tu ID es: <strong id="socio-id"></strong></p>
            </div>
        </section>

        <section id="pedido">
            <h2>Realiza tu Pedido</h2>
            <form id="form-pedido" action="https://formspree.io/f/xnjwdygn" method="POST">
                <input type="email" name="Email" placeholder="Tu correo para confirmar" required>
                
                <div class="opcion-pedido">
                    <div><input type="checkbox" id="check-nueces" name="P_Nueces"> <label>Brownie Nueces</label></div>
                    <input type="number" id="cant-nueces" name="Cant_Nueces" value="1" min="1" style="width:60px;">
                </div>
                <div class="opcion-pedido">
                    <div><input type="checkbox" id="check-rojo" name="P_RedVelvet"> <label>Red Velvet</label></div>
                    <input type="number" id="cant-rojo" name="Cant_RedVelvet" value="1" min="1" style="width:60px;">
                </div>
                <div class="opcion-pedido">
                    <div><input type="checkbox" id="check-melco" name="P_Melcochoso"> <label>Melcochoso</label></div>
                    <input type="number" id="cant-melco" name="Cant_Melcochoso" value="1" min="1" style="width:60px;">
                </div>
                <div class="opcion-pedido">
                    <div><input type="checkbox" id="check-base" name="P_Tradicional"> <label>Tradicional</label></div>
                    <input type="number" id="cant-base" name="Cant_Tradicional" value="1" min="1" style="width:60px;">
                </div>

                <button type="submit" class="btn-orden">Enviar Pedido</button>
            </form>
        </section>
    </main>

    <footer>
        <div class="footer-info">
            <div>
                <h3>Ubicación</h3>
                <p>La Chorrera, Panamá Oeste<br>Área de la Feria / PPS</p>
            </div>
            <div>
                <h3>Horario de Atención</h3>
                <p>Lunes a Sábado: 10:00 AM - 6:00 PM<br>Domingos: Cerrado</p>
            </div>
        </div>
        <p><small>&copy; 2026 Postreland. Todos los derechos reservados.</small></p>
    </footer>

    <script>
        function seleccionar(c, n) {
            document.getElementById(c).checked = true;
            document.getElementById('pedido').scrollIntoView();
            document.getElementById(n).focus();
        }

        document.getElementById('form-registro').addEventListener('submit', function(e) {
            e.preventDefault();
            const nombre = document.getElementById('reg-nombre').value;
            const id = "PL-" + Math.floor(Math.random() * 9000 + 1000);
            document.getElementById('socio-nombre').innerText = nombre;
            document.getElementById('socio-id').innerText = id;
            document.getElementById('mensaje-socio').style.display = 'block';
            this.reset();
        });
    </script>
</body>
</html>
